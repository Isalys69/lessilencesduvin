##############################################
# .gitignore — Les Silences du Vin
# V1 PRODUCTION — strict, sécurisé, reproductible
##############################################

# ==================================================
# 🖥️ SYSTÈME & ÉDITEURS
# ==================================================
.DS_Store
Thumbs.db
.idea/
.vscode/

# ==================================================
# 🐍 PYTHON — caches & artefacts
# ==================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# ==================================================
# 🌱 ENVIRONNEMENTS VIRTUELS
# ==================================================
venv/
ENV/
env/
.env
*.env

# ==================================================
# 🔐 SECRETS & CONFIGURATION SENSIBLE
# ==================================================
.env.*
*.key
*.pem
*.crt

# ==================================================
# 🗄️ BASES DE DONNÉES (JAMAIS VERSIONNÉES)
# ==================================================
*.db
*.db.*
*.sqlite
*.sqlite3
*.db.backup.*
*.sqlite.backup.*

# Cas explicites (lisibilité & sécurité)
app/data/*.db
app/data/*.db.*
app/data/*.db.backup.*
instance/*.db
instance/*.sqlite*

# ==================================================
# 🧾 LOGS (risque RGPD / secrets)
# ==================================================
*.log
app/data/app.log
logs/
log/

# ==================================================
# 🧱 FLASK — instance & runtime
# ==================================================
instance/
*.sock

# ==================================================
# 🧰 FICHIERS TEMPORAIRES / PERSONNELS
# ==================================================
*.bak.*
*.swp
*.swo
*~
.cache/
.pytest_cache/

# ==================================================
# 🗂️ BACKUPS & ARCHIVES LOCALES
# ==================================================
sauvegardes/
backup/
backups/
dump/

# ==================================================
# 🧪 OUTILS / SCRIPTS OBSOLÈTES
# (mémoire conservée ailleurs si nécessaire)
# ==================================================
app/new_initdb.py
app/old__init__.py
app/old_routes.py
old-initdb.py
app/templates/old.shoppingbasket.html
reset_admin_password.py
app/utils/reset_admin_password.py


# ==================================================
# 🖼️ ASSETS OBSOLÈTES
# ==================================================
app/static/img/vins/old*

# ==================================================
# ✅ FICHIERS À VERSIONNER EXPLICITEMENT
# ==================================================
# - app/data/schema.sql
# - app/data/seed.sql (si créé)
# - tout le code applicatif
##############################################
.env_version

# ─────────────────────────────
# Local development artifacts
# (Bloc 5 hygiene - safe additions)
# ─────────────────────────────
.open
app/db/
*.sqlite
*.sqlite3
